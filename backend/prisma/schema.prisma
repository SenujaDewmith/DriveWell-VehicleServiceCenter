generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Role {
  role_id   Int    @id @default(autoincrement())
  role_name String @unique @db.VarChar(50)
  users     User[]

  @@map("roles")
}

model User {
  user_id        Int      @id @default(autoincrement())
  email          String   @unique @db.VarChar(150)
  password_hash  String   @db.VarChar(255)
  role_id        Int
  account_status String   @default("active") @db.VarChar(30)
  created_at     DateTime @default(now())

  role     Role      @relation(fields: [role_id], references: [role_id])
  customer Customer?
  staff    Staff?

  vehicles           Vehicle[]                @relation("CustomerVehicles")
  reservations       Reservation[]            @relation("CustomerReservations")
  supervised_records ServiceRecord[]          @relation("SupervisorRecords")
  staff_assignments  ServiceStaffAssignment[]
  invoices_issued    Invoice[]                @relation("CashierInvoices")
  feedback_submitted Feedback[]               @relation("CustomerFeedback")
  activity_logs      ActivityLog[]

  @@map("users")
}

model Customer {
  user_id   Int     @id
  full_name String  @db.VarChar(150)
  phone     String? @db.VarChar(20)
  address   String?

  user User @relation(fields: [user_id], references: [user_id], onDelete: Cascade)

  @@map("customers")
}

model Staff {
  user_id   Int     @id
  full_name String  @db.VarChar(150)
  phone_no  String? @db.VarChar(20)

  user User @relation(fields: [user_id], references: [user_id], onDelete: Cascade)

  @@map("staff")
}

model VehicleMake {
  make_id Int    @id
  name    String @db.VarChar(100)

  models   VehicleModel[]
  vehicles Vehicle[]

  @@map("vehicle_makes")
}

model VehicleModel {
  model_id        Int     @id
  name            String  @db.VarChar(150)
  make_id         Int
  start_year      Int?
  end_year        Int?
  vehicle_type_id Int?

  make         VehicleMake  @relation(fields: [make_id], references: [make_id])
  vehicle_type VehicleType? @relation(fields: [vehicle_type_id], references: [type_id])
  vehicles     Vehicle[]

  @@map("vehicle_models")
}

model VehicleType {
  type_id Int    @id
  name    String @db.VarChar(50)

  models   VehicleModel[]
  vehicles Vehicle[]

  @@map("vehicle_types")
}

model Vehicle {
  vehicle_id      Int      @id @default(autoincrement())
  customer_id     Int
  make_id         Int
  model_id        Int
  vehicle_type_id Int
  year            Int?
  plate_no        String   @unique @db.VarChar(30)
  created_at      DateTime @default(now())

  customer     User         @relation("CustomerVehicles", fields: [customer_id], references: [user_id], onDelete: Cascade)
  make         VehicleMake  @relation(fields: [make_id], references: [make_id])
  model        VehicleModel @relation(fields: [model_id], references: [model_id])
  vehicle_type VehicleType  @relation(fields: [vehicle_type_id], references: [type_id])
  reservations Reservation[]

  @@map("vehicles")
}

model ServicePackage {
  package_id         Int      @id @default(autoincrement())
  name               String   @db.VarChar(150)
  package_code       String?  @unique @db.VarChar(20)
  description        String?
  estimated_duration Int      @default(60)
  price              Decimal  @db.Decimal(10, 2)
  image_url          String?  @db.VarChar(500)
  max_capacity       Int      @default(3)
  is_active          Boolean  @default(true)
  // Manager-curated pick for the "Popular Service Packages" section on the public landing
  // page — deliberately not derived from booking counts (see project notes: a manually
  // curated highlight avoids just crowning whichever package is cheapest/highest-volume).
  is_featured        Boolean  @default(false)
  created_at         DateTime @default(now())

  reservations Reservation[]

  @@map("service_packages")
}

model WorkingConfig {
  config_id               Int      @id @default(autoincrement())
  working_days            String   @default("1,2,3,4,5")
  day_start_time          DateTime @db.Time
  day_end_time            DateTime @db.Time
  // Same-day bookings stop being accepted this many minutes before closing —
  // e.g. 240 (4h) with an 18:00 close means no new same-day bookings after 14:00.
  same_day_cutoff_minutes Int      @default(240)

  @@map("working_config")
}

model BlockedTime {
  block_id   Int       @id @default(autoincrement())
  date       DateTime? @db.Date
  start_time DateTime  @db.Time
  end_time   DateTime  @db.Time
  reason     String?   @db.VarChar(255)
  created_at DateTime  @default(now())

  @@map("blocked_times")
}

model Reservation {
  reservation_id Int      @id @default(autoincrement())
  booking_ref    String?  @unique @db.VarChar(20)
  customer_id    Int
  vehicle_id     Int
  package_id     Int
  start_time     DateTime @db.Time
  end_time       DateTime @db.Time
  service_date   DateTime @db.Date
  status         String   @default("Booked") @db.VarChar(30)
  created_at     DateTime @default(now())
  // Clickwrap consent record — which T&C version the customer accepted and when.
  // Nullable because reservations created before this feature carry no acceptance.
  terms_version     String?   @db.VarChar(10)
  terms_accepted_at DateTime?

  customer_user  User           @relation("CustomerReservations", fields: [customer_id], references: [user_id])
  vehicle        Vehicle        @relation(fields: [vehicle_id], references: [vehicle_id])
  package        ServicePackage @relation(fields: [package_id], references: [package_id])
  service_record ServiceRecord?
  invoice        Invoice?
  feedback       Feedback?

  @@map("reservations")
}

model ServiceRecord {
  record_id             Int       @id @default(autoincrement())
  reservation_id        Int       @unique
  supervisor_id         Int?
  remarks               String?
  quality_checked       Boolean   @default(false)
  // Odometer reading is only collected when this service involved an oil
  // change (engine or gear oil) — supervisor self-declares via has_oil_change
  // rather than it being inferred from the package/catalog.
  has_oil_change        Boolean   @default(false)
  current_odometer      Int?
  next_service_odometer Int?
  started_at            DateTime?
  completed_at          DateTime?

  reservation Reservation @relation(fields: [reservation_id], references: [reservation_id], onDelete: Cascade)
  supervisor  User?                     @relation("SupervisorRecords", fields: [supervisor_id], references: [user_id])
  assignments ServiceStaffAssignment[]
  items       ServiceRecordItem[]

  @@map("service_records")
}

model ServiceStaffAssignment {
  assignment_id Int     @id @default(autoincrement())
  record_id     Int
  staff_id      Int
  work_note     String? @db.VarChar(255)

  record ServiceRecord @relation(fields: [record_id], references: [record_id], onDelete: Cascade)
  staff  User          @relation(fields: [staff_id], references: [user_id])

  @@unique([record_id, staff_id])
  @@map("service_staff_assignments")
}

// Manager-curated catalog of common additional repair/part charges — the
// reference price list the cashier draws from when itemizing an invoice.
model ChargeCatalogItem {
  catalog_item_id Int      @id @default(autoincrement())
  name            String   @db.VarChar(150)
  description     String?
  default_price   Decimal  @db.Decimal(10, 2)
  category        String?  @db.VarChar(50)
  is_active       Boolean  @default(true)
  created_at      DateTime @default(now())

  service_record_items ServiceRecordItem[]
  invoice_items         InvoiceItem[]

  @@map("charge_catalog_items")
}

// Structured note of additional work/parts a supervisor found necessary during
// a service — documentation only, no price. The cashier prices these at invoice time.
model ServiceRecordItem {
  item_id         Int      @id @default(autoincrement())
  record_id       Int
  catalog_item_id Int?
  description     String   @db.VarChar(255)
  quantity        Int      @default(1)
  created_at      DateTime @default(now())

  record       ServiceRecord      @relation(fields: [record_id], references: [record_id], onDelete: Cascade)
  catalog_item ChargeCatalogItem? @relation(fields: [catalog_item_id], references: [catalog_item_id])

  @@map("service_record_items")
}

model Invoice {
  invoice_id         Int      @id @default(autoincrement())
  reservation_id     Int      @unique
  cashier_id         Int?
  base_amount        Decimal  @db.Decimal(10, 2)
  additional_charges Decimal  @default(0) @db.Decimal(10, 2)
  discount           Decimal  @default(0) @db.Decimal(10, 2)
  total_amount       Decimal  @db.Decimal(10, 2)
  payment_status     String   @default("Unpaid") @db.VarChar(20)
  payment_method     String?  @db.VarChar(30)
  notes              String?
  generated_at       DateTime @default(now())

  reservation Reservation   @relation(fields: [reservation_id], references: [reservation_id])
  cashier     User?         @relation("CashierInvoices", fields: [cashier_id], references: [user_id])
  items       InvoiceItem[]

  @@map("invoices")
}

// Itemized invoice line — one per additional repair/part charge the cashier applies,
// priced with the manager's charge catalog as reference (editable per case).
model InvoiceItem {
  invoice_item_id Int      @id @default(autoincrement())
  invoice_id      Int
  catalog_item_id Int?
  description     String   @db.VarChar(255)
  unit_price      Decimal  @db.Decimal(10, 2)
  quantity        Int      @default(1)
  line_total      Decimal  @db.Decimal(10, 2)

  invoice      Invoice            @relation(fields: [invoice_id], references: [invoice_id], onDelete: Cascade)
  catalog_item ChargeCatalogItem? @relation(fields: [catalog_item_id], references: [catalog_item_id])

  @@map("invoice_items")
}

model Feedback {
  feedback_id    Int      @id @default(autoincrement())
  reservation_id Int      @unique
  customer_id    Int
  rating         Int
  comment        String?
  submitted_at   DateTime @default(now())

  reservation Reservation @relation(fields: [reservation_id], references: [reservation_id])
  customer    User        @relation("CustomerFeedback", fields: [customer_id], references: [user_id])

  @@map("feedback")
}

model ActivityLog {
  log_id      Int      @id @default(autoincrement())
  user_id     Int?
  action      String   @db.VarChar(255)
  entity_type String?  @db.VarChar(50)
  entity_id   Int?
  created_at  DateTime @default(now())

  user User? @relation(fields: [user_id], references: [user_id])

  @@map("activity_log")
}
